---
import Base from '../layouts/Base.astro';
import { getAllClaimSlugs } from '../lib/fetchClaimEvidence';

const slugs = await getAllClaimSlugs();
---

<Base
  title="Evidence Decoded Archive"
  description="Daily-built static archive of health claim evidence pages from Evidence Decoded."
  canonicalUrl="/"
  ogType="website"
>
  <h1 class="text-3xl font-bold mb-4">Evidence Decoded Archive</h1>
  <p class="text-gray-400 mb-10 max-w-2xl">
    Static snapshots of all health claim evidence pages, rebuilt daily. Each page is fully indexed by
    search engines. For voting, commenting, and expert reviews, visit the
    <a href="https://healthintegrityproject.org" class="text-teal-400 hover:underline">live app</a>.
  </p>

  <section>
    <h2 class="text-xl font-semibold mb-6 text-gray-200">All Claims ({slugs.length})</h2>
    <ul class="space-y-3">
      {slugs.map((slug) => (
        <li>
          <a
            href={`/claims/${slug}/evidence`}
            class="block px-4 py-3 rounded-lg bg-gray-900 border border-gray-800 hover:border-teal-500 transition-colors text-gray-200 hover:text-white"
          >
            {slug.replace(/-/g, ' ')}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
