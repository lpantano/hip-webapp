---
import Base from '../../../layouts/Base.astro';
import { getAllClaimSlugs, getClaimEvidence } from '../../../lib/fetchClaimEvidence';
import type { Publication, PublicationScore, ExpertProfile } from '../../../lib/types';

export async function getStaticPaths() {
  const slugs = await getAllClaimSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const claim = await getClaimEvidence(slug);

if (!claim) return Astro.redirect('/');

const appUrl = `https://healthintegrityproject.org/claims/${slug}/evidence`;
const buildDate = new Date().toISOString().split('T')[0];

const supporting = claim.publications.filter((p) => p.stance === 'supporting');
const contradicting = claim.publications.filter((p) => p.stance === 'contradicting');
const neutral = claim.publications.filter(
  (p) => p.stance === 'neutral' || p.stance === 'mixed' || !p.stance
);

function scoresFor(pubId: string): PublicationScore[] {
  return claim!.scores.filter((s) => s.publication_id === pubId);
}

function expertFor(userId: string): ExpertProfile | undefined {
  return claim!.experts.find((e) => e.user_id === userId);
}

function evidenceBadgeClass(status: string | null): string {
  switch (status) {
    case 'Evidence Supports':  return 'bg-teal-700 text-teal-100';
    case 'Evidence Disproves': return 'bg-orange-700 text-orange-100';
    case 'Inconclusive':       return 'bg-yellow-700 text-yellow-100';
    default:                   return 'bg-gray-700 text-gray-200';
  }
}

function stanceBorderClass(stance: string | null): string {
  switch (stance) {
    case 'supporting':    return 'border-l-teal-500';
    case 'contradicting': return 'border-l-orange-500';
    default:              return 'border-l-gray-600';
  }
}

function qualityCheckLabel(val: string | null | undefined): string {
  if (val === 'PASS') return '✓';
  if (val === 'NO')   return '✗';
  if (val === 'NA')   return 'N/A';
  return '—';
}
---

<Base
  title={claim.title}
  description={`Expert evidence and scientific papers for: ${claim.title}`}
  canonicalUrl={`/claims/${slug}/evidence`}
>
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/" class="hover:text-gray-300 transition-colors">Archive</a>
    <span class="mx-2">›</span>
    <span class="text-gray-300">Evidence</span>
  </nav>

  {claim.evidence_status && (
    <span class={`inline-block px-3 py-1 rounded-full text-sm font-semibold mb-4 ${evidenceBadgeClass(claim.evidence_status)}`}>
      {claim.evidence_status}
    </span>
  )}

  <h1 class="text-2xl sm:text-3xl font-bold mb-4 leading-snug">{claim.title}</h1>

  {claim.description && (
    <p class="text-gray-400 mb-8 leading-relaxed max-w-3xl">{claim.description}</p>
  )}

  <div class="bg-gray-900 border border-gray-700 rounded-lg p-4 mb-10 flex flex-col sm:flex-row sm:items-center gap-3">
    <p class="text-sm text-gray-400 flex-1">
      Static snapshot — vote, comment, and submit papers on the live app.
    </p>
    <a
      href={appUrl}
      class="inline-block px-4 py-2 bg-teal-700 hover:bg-teal-600 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap"
      target="_blank"
      rel="noopener noreferrer"
    >
      Open in Live App →
    </a>
  </div>

  {claim.publications.length === 0 ? (
    <div class="text-center py-16 text-gray-500 border border-gray-800 rounded-lg">
      No papers submitted for this claim yet.
    </div>
  ) : (
    <div class="space-y-12">
      {supporting.length > 0 && (
        <section aria-label="Supporting evidence">
          <h2 class="text-xl font-bold mb-5 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-teal-500 inline-block" aria-hidden="true"></span>
            Supporting Evidence
            <span class="text-sm font-semibold bg-teal-700 text-teal-100 px-2 py-0.5 rounded-full">
              {supporting.length}
            </span>
          </h2>
          <ul class="space-y-4">
            {supporting.map((pub) => {
              const pubScores = scoresFor(pub.id);
              return (
                <li class={`bg-gray-900 border border-gray-800 border-l-4 ${stanceBorderClass(pub.stance)} rounded-lg p-5`}>
                  <h3 class="font-semibold text-white mb-1 leading-snug">
                    {pub.url || pub.doi ? (
                      <a
                        href={pub.url ?? `https://doi.org/${pub.doi}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-teal-400 transition-colors"
                      >
                        {pub.title}
                      </a>
                    ) : pub.title}
                  </h3>
                  <p class="text-sm text-gray-400 mb-3">
                    {[pub.journal, pub.publication_year].filter(Boolean).join(' · ')}
                  </p>
                  {pubScores.length > 0 && (
                    <div class="mt-3 space-y-3">
                      {pubScores.map((score) => {
                        const expert = expertFor(score.expert_user_id);
                        const qc = score.review_data?.qualityChecks as Record<string, string> | undefined;
                        return (
                          <div class="bg-gray-800 rounded-md p-3 text-sm">
                            <p class="font-medium text-gray-300 mb-2">
                              Expert review{expert?.display_name ? `: ${expert.display_name}` : ''}
                            </p>
                            {qc && (
                              <ul class="text-gray-400 space-y-0.5">
                                <li>Study design: <span class="text-white">{qualityCheckLabel(qc.studyDesign)}</span></li>
                                <li>Control group: <span class="text-white">{qualityCheckLabel(qc.controlGroup)}</span></li>
                                <li>Bias addressed: <span class="text-white">{qualityCheckLabel(qc.biasAddressed)}</span></li>
                                <li>Statistics: <span class="text-white">{qualityCheckLabel(qc.statistics)}</span></li>
                              </ul>
                            )}
                            {score.comments && (
                              <p class="mt-2 text-gray-300 italic">"{score.comments}"</p>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {contradicting.length > 0 && (
        <section aria-label="Contradicting evidence">
          <h2 class="text-xl font-bold mb-5 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-orange-500 inline-block" aria-hidden="true"></span>
            Contradicting Evidence
            <span class="text-sm font-semibold bg-orange-700 text-orange-100 px-2 py-0.5 rounded-full">
              {contradicting.length}
            </span>
          </h2>
          <ul class="space-y-4">
            {contradicting.map((pub) => {
              const pubScores = scoresFor(pub.id);
              return (
                <li class={`bg-gray-900 border border-gray-800 border-l-4 ${stanceBorderClass(pub.stance)} rounded-lg p-5`}>
                  <h3 class="font-semibold text-white mb-1 leading-snug">
                    {pub.url || pub.doi ? (
                      <a
                        href={pub.url ?? `https://doi.org/${pub.doi}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-orange-400 transition-colors"
                      >
                        {pub.title}
                      </a>
                    ) : pub.title}
                  </h3>
                  <p class="text-sm text-gray-400 mb-3">
                    {[pub.journal, pub.publication_year].filter(Boolean).join(' · ')}
                  </p>
                  {pubScores.length > 0 && (
                    <div class="mt-3 space-y-3">
                      {pubScores.map((score) => {
                        const expert = expertFor(score.expert_user_id);
                        const qc = score.review_data?.qualityChecks as Record<string, string> | undefined;
                        return (
                          <div class="bg-gray-800 rounded-md p-3 text-sm">
                            <p class="font-medium text-gray-300 mb-2">
                              Expert review{expert?.display_name ? `: ${expert.display_name}` : ''}
                            </p>
                            {qc && (
                              <ul class="text-gray-400 space-y-0.5">
                                <li>Study design: <span class="text-white">{qualityCheckLabel(qc.studyDesign)}</span></li>
                                <li>Control group: <span class="text-white">{qualityCheckLabel(qc.controlGroup)}</span></li>
                                <li>Bias addressed: <span class="text-white">{qualityCheckLabel(qc.biasAddressed)}</span></li>
                                <li>Statistics: <span class="text-white">{qualityCheckLabel(qc.statistics)}</span></li>
                              </ul>
                            )}
                            {score.comments && (
                              <p class="mt-2 text-gray-300 italic">"{score.comments}"</p>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {neutral.length > 0 && (
        <section aria-label="Neutral or mixed evidence">
          <h2 class="text-xl font-bold mb-5 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-gray-500 inline-block" aria-hidden="true"></span>
            Neutral / Mixed
            <span class="text-sm font-semibold bg-gray-700 text-gray-200 px-2 py-0.5 rounded-full">
              {neutral.length}
            </span>
          </h2>
          <ul class="space-y-4">
            {neutral.map((pub) => (
              <li class={`bg-gray-900 border border-gray-800 border-l-4 ${stanceBorderClass(pub.stance)} rounded-lg p-5`}>
                <h3 class="font-semibold text-white mb-1 leading-snug">
                  {pub.url || pub.doi ? (
                    <a
                      href={pub.url ?? `https://doi.org/${pub.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-gray-300 transition-colors"
                    >
                      {pub.title}
                    </a>
                  ) : pub.title}
                </h3>
                <p class="text-sm text-gray-400">
                  {[pub.journal, pub.publication_year].filter(Boolean).join(' · ')}
                </p>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}

  <p class="mt-16 text-xs text-gray-600 text-right">Snapshot built: {buildDate}</p>
</Base>
